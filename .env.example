# Simple Crew Builder - Environment Variables Configuration
# Copy this file to .env and adjust the values as needed.

# --- OpenAI Configuration ---
# Your OpenAI API Key (Required for AI features if not set via UI)
OPENAI_API_KEY=

# --- Database Configuration (PostgreSQL) ---
# Defaults to 'postgres' if not set
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=simple-crew-builder

# --- Neo4j Configuration ---
# Defaults to 'neo4j' and 'simplecrew2026' if not set
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=simplecrew2026

# Bolt URI for backend connection (Internal Docker DNS)
NEO4J_URI=bolt://neo4j:7687
